    ]
  },
  {
    id: 'jade',
    name: 'Jade',
    age: 23,
    height: "5'5\"",
    hair: 'Exotic High Energy',
    cupSize: '34DD',
    measurements: '34-24-35',
    tags: ['Party Favorite', 'High Energetic', 'Exotic Queen'],
    image: gateBg,
    bio: 'Captivating, exotic companion who loves hosting premium Vegas bachelor parties, interactive events, and VIP table packages. Energetic and legally compliant.',
    rating: 4.9,
    languages: ['English', 'Mandarin'],
    gallery: [
      'https://images.unsplash.com/photo-1562572159-4ebcd318f4dd?auto=format&fit=crop&q=80&w=400',
