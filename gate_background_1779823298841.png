export const eliteGirls: Girl[] = [
  {
    id: 'bella',
    name: 'Bella',
    age: 23,
    height: "5'8\"",
    hair: 'Seductive VIP Elite',
    cupSize: '34DD',
    measurements: '34-24-36',
